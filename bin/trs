#!/usr/bin/env -S uv run --script
# -*- mode: python-*- vim: ft=python
# /// script
# requires-python = ">=3.12"
# dependencies = ["click>=8", "rich>=13", "pydantic>=2"]
# ///
"""trs — transcript search over Claude Code sessions (SQLite FTS5)"""

from __future__ import annotations

import json
import os
import re
import shutil
import sqlite3
import sys
import tomllib
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

import click
from pydantic import BaseModel, ConfigDict, Field, ValidationError
from rich.console import Console
from rich.style import Style
from rich.text import Text

# --- paths ---

PROJECTS_DIR = Path.home() / ".claude" / "projects"
_xdg_data = Path(os.environ.get("XDG_DATA_HOME") or Path.home() / ".local" / "share")
_xdg_config = Path(os.environ.get("XDG_CONFIG_HOME") or Path.home() / ".config")
DB_PATH = _xdg_data / "trs" / "index.db"
PROFILES_PATH = _xdg_config / "trs" / "profiles.toml"

FILE_TOOLS = {"Write", "Edit", "Read", "MultiEdit"}

INDEX_INCREMENTAL = "index"
INDEX_FULL = "reindex"
INDEX_SKIP = "no-index"

console = Console()


# --- schema ---

SCHEMA = """
CREATE TABLE IF NOT EXISTS sessions (
    session_id    TEXT PRIMARY KEY,
    source        TEXT NOT NULL DEFAULT 'claude-code',
    cwd           TEXT,
    slug          TEXT,
    git_branches  TEXT,
    start_time    TEXT,
    end_time      TEXT,
    files_touched TEXT,
    tools_used    TEXT,
    message_count INTEGER DEFAULT 0,
    first_message TEXT,
    summary       TEXT,
    indexed_at    TEXT NOT NULL,
    source_mtime  REAL NOT NULL,
    content_hash  TEXT,
    metadata      TEXT
);

CREATE VIRTUAL TABLE IF NOT EXISTS sessions_fts USING fts5(
    session_id   UNINDEXED,
    cwd,
    git_branches,
    summary,
    first_message,
    files_touched,
    body,
    tokenize = 'porter unicode61'
);

CREATE TABLE IF NOT EXISTS schema_version (version INTEGER PRIMARY KEY);
"""

CURRENT_VERSION = 2

MIGRATIONS: dict[int, list[str]] = {
    2: [
        "ALTER TABLE sessions ADD COLUMN content_hash TEXT",
        "ALTER TABLE sessions ADD COLUMN metadata TEXT",
    ],
}


def _run_migrations(con: sqlite3.Connection) -> None:
    con.execute("CREATE TABLE IF NOT EXISTS schema_version (version INTEGER PRIMARY KEY)")
    row = con.execute("SELECT MAX(version) AS v FROM schema_version").fetchone()
    current = row["v"] or 0
    for version in sorted(MIGRATIONS):
        if version <= current:
            continue
        for stmt in MIGRATIONS[version]:
            try:
                con.execute(stmt)
            except sqlite3.OperationalError:
                pass  # duplicate column or no such table — safe to ignore
        con.execute("INSERT OR IGNORE INTO schema_version (version) VALUES (?)", (version,))
        con.commit()


def open_db(path: Path, init: bool = False) -> sqlite3.Connection:
    path.parent.mkdir(parents=True, exist_ok=True)
    con = sqlite3.connect(path)
    con.row_factory = sqlite3.Row
    if init:
        con.executescript(SCHEMA)
        con.commit()
    _run_migrations(con)
    return con


# --- models ---

class Session(BaseModel):
    session_id: str
    slug: str = ""
    source: str = "claude-code"
    cwd: str = ""
    git_branches: list[str] = Field(default_factory=list)
    start_time: str = ""
    end_time: str = ""
    files_touched: list[str] = Field(default_factory=list)
    tools_used: list[str] = Field(default_factory=list)
    message_count: int = 0
    first_message: str = ""
    summary: str = ""
    body: str = ""
    content_hash: str | None = None
    metadata: dict[str, Any] = Field(default_factory=dict)


class IngestRecord(BaseModel):
    model_config = ConfigDict(extra="allow")

    session_id: str = Field(description="Stable unique ID for this conversation")
    source: str = Field(description='Application name (e.g. "codex", "slack")')
    body: str = Field(description="Full text content for full-text search")
    start_time: str = Field(default="", description="ISO 8601 timestamp")
    end_time: str = Field(default="", description="ISO 8601 timestamp")
    first_message: str = Field(default="", description="Opening message (shown in search results)")
    summary: str = Field(default="", description="Short description (shown in search results)")
    message_count: int = Field(default=0, description="Number of messages in conversation")
    cwd: str = Field(default="", description="Working directory or context path")
    slug: str = Field(default="", description="Conversation title / channel name")
    git_branches: list[str] = Field(default_factory=list, description="Git branches active during session")
    files_touched: list[str] = Field(default_factory=list, description="File paths referenced")
    tools_used: list[str] = Field(default_factory=list, description="Tool/command names used")
    content_hash: str | None = Field(default=None, description="SHA-256 of source content (enables dedup on re-ingest)")

    def to_session(self) -> Session:
        known = set(IngestRecord.model_fields)
        return Session(
            **{k: getattr(self, k) for k in known},
            metadata=self.model_extra or {},
        )


# --- profile config ---

class FieldProfile(BaseModel):
    source: str | None = None
    fields: dict[str, str] = Field(default_factory=dict)
    defaults: dict[str, Any] = Field(default_factory=dict)


class ProfilesConfig(BaseModel):
    profiles: dict[str, FieldProfile] = Field(default_factory=dict)


def _load_profiles(config_path: Path) -> ProfilesConfig:
    if not config_path.exists():
        return ProfilesConfig()
    with open(config_path, "rb") as f:
        data = tomllib.load(f)
    return ProfilesConfig.model_validate(data)


def _resolve_dot_path(obj: Any, path: str) -> Any:
    """Walk a.b.c path into nested dicts; return None if any key missing."""
    for part in path.split("."):
        if not isinstance(obj, dict):
            return None
        obj = obj.get(part)
    return obj


def apply_profile(record: dict[str, Any], profile: FieldProfile) -> dict[str, Any]:
    result: dict[str, Any] = dict(profile.defaults)
    remapped_keys: set[str] = set()

    for src_path, dst_field in profile.fields.items():
        value = _resolve_dot_path(record, src_path)
        if value is not None:
            result[dst_field] = value
        remapped_keys.add(src_path.split(".")[0])

    for key, value in record.items():
        if key not in remapped_keys and key not in result:
            result[key] = value

    if profile.source:
        result["source"] = profile.source

    return result


# --- JSONL parsing ---

def _text_from_content(content: Any) -> str:
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for block in content:
            if isinstance(block, dict) and block.get("type") == "text":
                parts.append(block.get("text", ""))
        return " ".join(parts)
    return ""


def _rec_content(rec: dict) -> Any:
    """Extract message content from a JSONL record."""
    msg = rec.get("message") or {}
    return msg.get("content") if isinstance(msg, dict) else None


def parse_session(path: Path) -> Session:
    slug = path.parent.name
    session_id = path.stem
    body_parts: list[str] = []
    branches: set[str] = set()
    files: set[str] = set()
    tools: set[str] = set()
    cwd = ""
    start_time = ""
    end_time = ""
    message_count = 0
    first_message = ""
    summary = ""

    with open(path, encoding="utf-8", errors="replace") as f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            try:
                rec = json.loads(raw)
            except json.JSONDecodeError:
                continue

            rtype = rec.get("type")

            if rec.get("cwd") and not cwd:
                cwd = rec["cwd"]
            if rec.get("gitBranch"):
                branches.add(rec["gitBranch"])
            ts = rec.get("timestamp", "")
            if ts:
                if not start_time:
                    start_time = ts
                end_time = ts

            if rtype == "user":
                content = _rec_content(rec)
                if content is None:
                    content = rec.get("content")
                text = _text_from_content(content)
                if text:
                    message_count += 1
                    if not first_message:
                        first_message = text[:500]
                    body_parts.append(text[:1000])

            elif rtype == "assistant":
                content = _rec_content(rec)
                if not isinstance(content, list):
                    continue
                message_count += 1
                for block in content:
                    if not isinstance(block, dict):
                        continue
                    btype = block.get("type")
                    if btype == "text":
                        text = block.get("text", "")
                        if text:
                            body_parts.append(text[:1000])
                    elif btype == "tool_use":
                        name = block.get("name", "")
                        inp = block.get("input") or {}
                        if name:
                            tools.add(name)
                        if name in FILE_TOOLS:
                            fp = inp.get("file_path", "")
                            if fp:
                                files.add(fp)
                        elif name == "Bash":
                            cmd = inp.get("command", "")
                            if cmd:
                                body_parts.append(cmd[:200])

            elif rtype == "summary":
                summ = rec.get("summary", "")
                if summ:
                    summary = summ

    return Session(
        session_id=session_id,
        slug=slug,
        cwd=cwd,
        start_time=start_time,
        end_time=end_time,
        message_count=message_count,
        first_message=first_message,
        summary=summary,
        git_branches=sorted(branches),
        files_touched=sorted(files),
        tools_used=sorted(tools),
        body=" ".join(body_parts),
    )


# --- indexer ---

def glob_sessions() -> list[Path]:
    paths = []
    for p in PROJECTS_DIR.rglob("*.jsonl"):
        parts = p.parts
        if "subagents" in parts or "tool-results" in parts:
            continue
        paths.append(p)
    return paths


def upsert_session(con: sqlite3.Connection, sess: Session, mtime: float) -> None:
    now = datetime.now(timezone.utc).isoformat()
    branches_json = json.dumps(sess.git_branches)
    files_json = json.dumps(sess.files_touched)
    tools_json = json.dumps(sess.tools_used)
    metadata_json = json.dumps(sess.metadata) if sess.metadata else None

    con.execute(
        """
        INSERT INTO sessions
            (session_id, source, cwd, slug, git_branches, start_time, end_time,
             files_touched, tools_used, message_count, first_message, summary,
             indexed_at, source_mtime, content_hash, metadata)
        VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        ON CONFLICT(session_id) DO UPDATE SET
            source=excluded.source, cwd=excluded.cwd, slug=excluded.slug,
            git_branches=excluded.git_branches, start_time=excluded.start_time,
            end_time=excluded.end_time, files_touched=excluded.files_touched,
            tools_used=excluded.tools_used, message_count=excluded.message_count,
            first_message=excluded.first_message, summary=excluded.summary,
            indexed_at=excluded.indexed_at, source_mtime=excluded.source_mtime,
            content_hash=excluded.content_hash, metadata=excluded.metadata
        """,
        (
            sess.session_id, sess.source, sess.cwd, sess.slug,
            branches_json, sess.start_time, sess.end_time,
            files_json, tools_json, sess.message_count,
            sess.first_message, sess.summary, now, mtime,
            sess.content_hash, metadata_json,
        ),
    )
    con.execute("DELETE FROM sessions_fts WHERE session_id = ?", (sess.session_id,))
    con.execute(
        """
        INSERT INTO sessions_fts
            (session_id, cwd, git_branches, summary, first_message, files_touched, body)
        VALUES (?,?,?,?,?,?,?)
        """,
        (
            sess.session_id, sess.cwd or "", branches_json, sess.summary,
            sess.first_message, " ".join(sess.files_touched), sess.body,
        ),
    )


# --- ingest ---

def run_ingest(
    db_path: Path,
    source_filter: str | None,
    profile: FieldProfile | None,
) -> None:
    con = open_db(db_path, init=True)

    existing: dict[str, str] = {
        row["session_id"]: row["content_hash"]
        for row in con.execute(
            "SELECT session_id, content_hash FROM sessions WHERE content_hash IS NOT NULL"
        )
        if row["content_hash"]
    }

    indexed = skipped = errors = 0
    for lineno, raw in enumerate(sys.stdin, 1):
        raw = raw.strip()
        if not raw:
            continue
        try:
            if profile is not None:
                raw_dict = json.loads(raw)
                raw_dict = apply_profile(raw_dict, profile)
                record = IngestRecord.model_validate(raw_dict)
            else:
                record = IngestRecord.model_validate_json(raw)
        except (ValidationError, json.JSONDecodeError, ValueError) as e:
            console.print(f"[yellow]Line {lineno}: validation error — {e}[/yellow]")
            errors += 1
            continue

        if source_filter and record.source != source_filter:
            skipped += 1
            continue

        if record.content_hash and existing.get(record.session_id) == record.content_hash:
            skipped += 1
            continue

        sess = record.to_session()
        upsert_session(con, sess, mtime=0.0)
        indexed += 1
        if indexed % 50 == 0:
            con.commit()

    con.commit()
    parts = [f"[green]{indexed}[/green] indexed", f"[dim]{skipped} skipped[/dim]"]
    if errors:
        parts.append(f"[red]{errors} errors[/red]")
    console.print(f"Done. {', '.join(parts)}.")


# --- display ---

def _duration(start: str, end: str) -> str:
    if not start or not end:
        return ""
    try:
        fmt = "%Y-%m-%dT%H:%M:%S.%fZ"
        t0 = datetime.strptime(start, fmt)
        t1 = datetime.strptime(end, fmt)
        secs = int((t1 - t0).total_seconds())
        if secs < 60:
            return f"{secs}s"
        mins = secs // 60
        if mins < 60:
            return f"{mins}m"
        return f"{mins // 60}h {mins % 60}m"
    except Exception:
        return ""


def _short_date(ts: str) -> str:
    if not ts:
        return ""
    return ts[:10]


_URL_RE = re.compile(r"https?://\S+")


def _linkify(text: str) -> Text:
    """Return a Text object with http(s) URLs turned into clickable links."""
    result = Text()
    last = 0
    for m in _URL_RE.finditer(text):
        result.append(text[last : m.start()])
        url = m.group()
        result.append(url, style=Style(link=url))
        last = m.end()
    result.append(text[last:])
    return result


def _files_summary(files_json: str) -> Text | None:
    try:
        files = json.loads(files_json or "[]")
    except Exception:
        return None
    if not files:
        return None
    show = files[:3]
    extra = len(files) - 3 if len(files) > 3 else 0
    result = Text()
    for i, fpath in enumerate(show):
        if i:
            result.append(", ")
        result.append(Path(fpath).name, style=Style(link=f"file://{fpath}"))
    if extra:
        result.append(f" (+{extra})", style="dim")
    return result


def display_result(row: sqlite3.Row) -> None:
    session_id = row["session_id"]
    slug = row["slug"] or ""
    cwd = row["cwd"] or ""
    branches = json.loads(row["git_branches"] or "[]")
    start = row["start_time"] or ""
    end = row["end_time"] or ""
    msgs = row["message_count"] or 0
    first_msg = row["first_message"] or ""
    summary = row["summary"] or ""
    files_json = row["files_touched"] or "[]"

    date = _short_date(start)
    dur = _duration(start, end)
    files_text = _files_summary(files_json)

    header = Text()
    header.append("● ", style="bold green")
    header.append(slug or session_id, style="bold")
    if date:
        header.append(f"  {date}", style="dim")
    if dur:
        header.append(f"  {dur}", style="dim")
    if msgs:
        header.append(f"  {msgs} msgs", style="dim")
    console.print(header)

    meta = Text("  ")
    meta.append(cwd, style=Style(color="cyan", link=f"file://{cwd}") if cwd else "cyan")
    if branches:
        meta.append("  ⎇  ", style="dim")
        meta.append(", ".join(branches), style="yellow")
    console.print(meta)

    desc = summary or first_msg
    if desc:
        desc = desc.replace("\n", " ").strip()
        if len(desc) > 120:
            desc = desc[:117] + "..."
        desc_text = Text("  ")
        desc_text.append_text(_linkify(desc))
        console.print(desc_text, style="italic")

    if files_text is not None:
        line = Text("  ")
        line.append("Files: ", style="dim")
        line.append_text(files_text)
        console.print(line)

    source = row["source"] or "claude-code"
    if source.startswith("claude"):
        console.print(f"  [dim]claude --resume {session_id}[/dim]")
    else:
        console.print(f"  [dim]{source}  {session_id}[/dim]")
    console.print()


# --- query normalization ---

def normalize_fts_query(query: str) -> str:
    """Quote hyphenated tokens to prevent FTS5 interpreting '-' as NOT operator.

    Only normalizes if the user hasn't already used explicit FTS5 syntax
    (quoted phrases, column scoping, etc.).
    """
    if '"' in query:
        return query  # user is being explicit
    parts = []
    for token in query.split():
        if not token.startswith("-") and "-" in token:
            parts.append(f'"{token}"')
        else:
            parts.append(token)
    return " ".join(parts)


# --- indexer (run) ---

def run_index(db_path: Path, full: bool = False) -> None:
    con = open_db(db_path, init=True)

    stored: dict[str, float] = {}
    db_ids: set[str] = set()
    for row in con.execute("SELECT session_id, source_mtime FROM sessions"):
        db_ids.add(row["session_id"])
        if not full:
            stored[row["session_id"]] = row["source_mtime"]

    paths = glob_sessions()
    live_ids = {p.stem for p in paths}
    total = len(paths)
    skipped = indexed = 0

    with click.progressbar(paths, label="Indexing", width=40) as bar:
        for path in bar:
            try:
                mtime = path.stat().st_mtime
            except OSError:
                continue

            sid = path.stem
            if not full and stored.get(sid, 0.0) >= mtime:
                skipped += 1
                continue

            try:
                sess = parse_session(path)
                upsert_session(con, sess, mtime)
                indexed += 1
                if indexed % 50 == 0:
                    con.commit()
            except Exception as e:
                console.print(f"\n[yellow]Warning:[/yellow] {path.name}: {e}")

    dead_ids = list(db_ids - live_ids)
    if dead_ids:
        placeholders = ",".join("?" * len(dead_ids))
        con.execute(f"DELETE FROM sessions WHERE session_id IN ({placeholders})", dead_ids)
        con.execute(f"DELETE FROM sessions_fts WHERE session_id IN ({placeholders})", dead_ids)

    con.commit()
    parts = [f"[green]{indexed}[/green] indexed", f"[dim]{skipped} skipped[/dim]"]
    if dead_ids:
        parts.append(f"[red]{len(dead_ids)} pruned[/red]")
    console.print(f"Done. {', '.join(parts)} (of {total} total).")
    console.print(f"[dim]DB: {db_path}[/dim]")


# --- db management ---

def run_clean(db_path: Path) -> None:
    if not db_path.exists():
        console.print("[dim]No index found.[/dim]")
        return
    click.confirm(f"Delete index at {db_path}?", abort=True)
    db_path.unlink()
    console.print(f"[green]Deleted[/green] {db_path}")


def run_export(db_path: Path, dest: Path) -> None:
    if not db_path.exists():
        console.print("[yellow]No index to export.[/yellow]")
        return
    dest = dest if dest.suffix else dest / db_path.name
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(db_path, dest)
    console.print(f"Exported [cyan]{db_path}[/cyan] → [cyan]{dest}[/cyan]")


def run_import(db_path: Path, src: Path) -> None:
    if not src.exists():
        console.print(f"[red]Source not found:[/red] {src}")
        return
    if db_path.exists():
        click.confirm(f"Overwrite existing index at {db_path}?", abort=True)
    db_path.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, db_path)
    console.print(f"Imported [cyan]{src}[/cyan] → [cyan]{db_path}[/cyan]")


# --- search ---

def run_search(
    query: str,
    db_path: Path,
    file_pat: str | None,
    branch_pat: str | None,
    project_pat: str | None,
    limit: int,
) -> None:
    if not db_path.exists():
        console.print("[yellow]Index not found. Run [bold]trs --index[/bold] first.[/yellow]")
        return

    con = open_db(db_path)

    where_clauses = []
    params: list[Any] = [query]
    if file_pat:
        where_clauses.append("s.files_touched LIKE ?")
        params.append(f"%{file_pat}%")
    if branch_pat:
        where_clauses.append("s.git_branches LIKE ?")
        params.append(f"%{branch_pat}%")
    if project_pat:
        where_clauses.append("s.cwd LIKE ?")
        params.append(f"%{project_pat}%")

    where_sql = ("WHERE " + " AND ".join(where_clauses)) if where_clauses else ""
    params.append(limit)

    sql = f"""
        WITH matches AS (
            SELECT session_id, rank
            FROM sessions_fts
            WHERE sessions_fts MATCH ?
        )
        SELECT s.*, m.rank
        FROM matches m
        JOIN sessions s USING (session_id)
        {where_sql}
        ORDER BY m.rank
        LIMIT ?
    """

    try:
        rows = con.execute(sql, params).fetchall()
    except sqlite3.OperationalError as e:
        console.print(f"[red]Query error:[/red] {e}")
        console.print(
            "[dim]Hint: wrap multi-word queries in quotes, e.g. trs '\"my phrase\"'[/dim]"
        )
        return

    if not rows:
        console.print("[dim]No results.[/dim]")
        return

    console.print(f"[dim]{len(rows)} result(s)[/dim]\n")
    for row in rows:
        display_result(row)


# --- CLI ---

class TrsGroup(click.Group):
    def invoke(self, ctx: click.Context) -> Any:
        import warnings

        with warnings.catch_warnings():
            warnings.simplefilter("ignore", DeprecationWarning)
            all_positional = list(ctx.protected_args) + list(ctx.args)

        if not all_positional:
            return super().invoke(ctx)

        first = all_positional[0]
        if self.get_command(ctx, first) is None:
            ctx.meta["trs_query"] = first
            ctx.invoked_subcommand = None
            return click.Command.invoke(self, ctx)

        return super().invoke(ctx)


SEARCH_OPTIONS = [
    click.option("--file", "-f", "file_pat", default=None, help="Filter by file path substring"),
    click.option("--branch", "-b", "branch_pat", default=None, help="Filter by git branch substring"),
    click.option("--project", "-p", "project_pat", default=None, help="Filter by cwd/project substring"),
    click.option("--limit", "-n", default=20, show_default=True, help="Max results"),
    click.option("--index", "index_mode", flag_value=INDEX_INCREMENTAL, help="Incremental index before search (default when query given)"),
    click.option("--reindex", "index_mode", flag_value=INDEX_FULL, help="Full reindex before search"),
    click.option("--no-index", "index_mode", flag_value=INDEX_SKIP, help="Skip indexing, use existing index as-is"),
    click.option("--clean", is_flag=True, default=False, help="Delete the index database"),
    click.option("--export", "export_path", default=None, type=click.Path(), metavar="PATH", help="Export index DB to PATH"),
    click.option("--import", "import_path", default=None, type=click.Path(), metavar="PATH", help="Import index DB from PATH"),
    click.option(
        "--db",
        default=str(DB_PATH),
        help="Index database path",
        show_default=True,
        envvar="TRS_DB",
    ),
]


def add_options(options: list) -> Any:
    def decorator(f: Any) -> Any:
        for opt in reversed(options):
            f = opt(f)
        return f
    return decorator


@click.group(
    cls=TrsGroup,
    invoke_without_command=True,
    context_settings=dict(
        allow_interspersed_args=True,
        ignore_unknown_options=True,
    ),
)
@add_options(SEARCH_OPTIONS)
@click.pass_context
def cli(
    ctx: click.Context,
    file_pat: str | None,
    branch_pat: str | None,
    project_pat: str | None,
    limit: int,
    index_mode: str | None,
    clean: bool,
    export_path: str | None,
    import_path: str | None,
    db: str,
) -> None:
    """Full-text search over Claude Code session transcripts.

    \b
    Positional args become the FTS5 query. Supports:
      plain words:     trs "LaunchDarkly migration"
      quoted phrase:   trs '"exact phrase"'
      prefix:          trs "migrat*"
      column scope:    trs "first_message:dynamo"

    \b
    Index is stored at $XDG_DATA_HOME/trs/index.db
    (default: ~/.local/share/trs/index.db); override with --db or $TRS_DB.

    \b
    Examples:
      trs "LaunchDarkly migration"
      trs "DynamoDB" --branch "saved-media"
      trs "kitty" --project "dotfiles"
      trs --index
      trs --reindex
      trs --export ~/backup.db
      trs --clean
    """
    if ctx.invoked_subcommand is not None:
        return

    raw_query = ctx.meta.get("trs_query") or ""
    db_path = Path(db)

    if import_path:
        run_import(db_path, Path(import_path))
        return

    if clean:
        run_clean(db_path)
        return

    if export_path:
        run_export(db_path, Path(export_path))
        return

    effective_mode = index_mode if index_mode is not None else (INDEX_INCREMENTAL if raw_query else None)

    if effective_mode in (INDEX_INCREMENTAL, INDEX_FULL):
        run_index(db_path, full=(effective_mode == INDEX_FULL))
        if not raw_query:
            return

    if not raw_query:
        click.echo(ctx.get_help())
        return

    query = normalize_fts_query(raw_query)
    run_search(query, db_path, file_pat, branch_pat, project_pat, limit)


@cli.command()
@click.option("--profile", "-P", default=None, help="Profile name from profiles.toml")
@click.option("--config", "config_path", default=None, type=click.Path(), help="Path to profiles TOML")
@click.option("--source", "-s", default=None, help="Only accept records with this source value")
@click.option("--db", default=str(DB_PATH), envvar="TRS_DB", show_default=True)
def ingest(profile: str | None, config_path: str | None, source: str | None, db: str) -> None:
    """Index transcripts from stdin (NDJSON, one session per line).

    Each line must be a JSON object with at minimum:
      session_id (str), source (str), body (str)

    Optional: start_time, end_time, first_message, summary, message_count,
              cwd, slug, git_branches, files_touched, tools_used, content_hash.
    Any extra fields are stored in the metadata column.
    """
    resolved_profile: FieldProfile | None = None
    if profile is not None:
        cfg_path = Path(config_path) if config_path else PROFILES_PATH
        cfg = _load_profiles(cfg_path)
        if profile not in cfg.profiles:
            raise click.ClickException(f"Profile {profile!r} not found in {cfg_path}")
        resolved_profile = cfg.profiles[profile]

    run_ingest(Path(db), source, resolved_profile)


@cli.command(name="profiles")
@click.option("--config", "config_path", default=None, type=click.Path(), help="Path to profiles TOML")
def list_profiles(config_path: str | None) -> None:
    """List profiles from profiles.toml."""
    cfg_path = Path(config_path) if config_path else PROFILES_PATH
    cfg = _load_profiles(cfg_path)
    if not cfg.profiles:
        console.print(f"[dim]No profiles found in {cfg_path}[/dim]")
        return
    console.print(f"[dim]{len(cfg.profiles)} profile(s) in {cfg_path}[/dim]\n")
    for name, prof in cfg.profiles.items():
        src = f"source={prof.source}" if prof.source else "—"
        field_count = len(prof.fields)
        default_count = len(prof.defaults)
        parts = [f"[bold]{name:<16}[/bold]", f"[dim]{src:<20}[/dim]"]
        if field_count:
            parts.append(f"{field_count} field mapping{'s' if field_count != 1 else ''}")
        if default_count:
            parts.append(f"{default_count} default{'s' if default_count != 1 else ''}")
        console.print("  " + "  ".join(parts))


@cli.command()
@click.option("--json", "as_json", is_flag=True, help="Emit raw JSON Schema")
def schema(as_json: bool) -> None:
    """Print canonical IngestRecord JSON schema."""
    if as_json:
        console.print(json.dumps(IngestRecord.model_json_schema(), indent=2))
        return

    console.print("[bold]IngestRecord[/bold] — canonical trs ingest format\n")
    console.print("[bold]Required fields:[/bold]")
    for fname in ("session_id", "source", "body"):
        f = IngestRecord.model_fields[fname]
        ftype = "string"
        console.print(f"  [cyan]{fname:<16}[/cyan] [dim]{ftype:<8}[/dim] {f.description}")

    console.print()
    console.print("[bold]Optional fields:[/bold]")
    optional_info = [
        ("start_time", "string"),
        ("end_time", "string"),
        ("first_message", "string"),
        ("summary", "string"),
        ("message_count", "integer"),
        ("cwd", "string"),
        ("slug", "string"),
        ("git_branches", "array"),
        ("files_touched", "array"),
        ("tools_used", "array"),
        ("content_hash", "string"),
    ]
    for fname, ftype in optional_info:
        f = IngestRecord.model_fields[fname]
        console.print(f"  [cyan]{fname:<16}[/cyan] [dim]{ftype:<8}[/dim] {f.description}")

    console.print()
    console.print("[dim]Extra fields: stored verbatim in metadata column (source-specific data).[/dim]")
    console.print()
    console.print("[bold]Example:[/bold]")
    console.print('  [dim]{"session_id":"abc","source":"codex","body":"full text","content_hash":"sha256..."}[/dim]')


if __name__ == "__main__":
    cli()
