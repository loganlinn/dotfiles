#!/usr/bin/env bash
# claude-desktop — open Claude Desktop via deep-link URIs.
#
# Claude Desktop registers the `claude://` URL scheme. On macOS, `open(1)` hands
# the URI to the app; on Linux, `xdg-open(1)` does the same.
#
# The supported routes were discovered two ways:
#
#   1. Extracting the Electron main-process JS from app.asar and reading the URL
#      handler switch statement (parse asar header → locate main JS by offset →
#      find the `open-url` event handler → map host/pathname cases to params).
#
#   2. Right-clicking elements in Claude Desktop → "Copy Link" yields https://
#      URLs whose paths map 1:1 to deep links (substitute https → claude).
#
# Both methods are reproducible on future versions.

set -euo pipefail

readonly MAX_PROMPT_LEN=14336 # ~14KB, enforced by the app
readonly UUID_RE='^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
readonly SETTINGS_PAGES='general account usage capabilities connectors claude-code cowork desktop desktop/extensions desktop/developer'

# --------------------------------------------------------------------------- #
# Helpers
# --------------------------------------------------------------------------- #

urlencode() {
  local str="$1" encoded='' i char
  for ((i = 0; i < ${#str}; i++)); do
    char="${str:$i:1}"
    case "$char" in
    [a-zA-Z0-9._~-]) encoded+="$char" ;;
    *) printf -v encoded '%s%%%02X' "$encoded" "'$char" ;;
    esac
  done
  printf '%s' "$encoded"
}

open_url() {
  local url="$1"
  case "$(uname -s)" in
  Darwin) open "$url" ;;
  Linux) xdg-open "$url" ;;
  *)
    echo >&2 "Unsupported platform: $(uname -s)"
    return 1
    ;;
  esac
}

is_uuid() {
  [[ "$1" =~ $UUID_RE ]]
}

require_uuid() {
  local value="$1" label="${2:-UUID}"
  if ! is_uuid "$value"; then
    echo >&2 "Invalid $label: $value"
    exit 1
  fi
}

# Build a claude:// URL: build_url HOST [PATH] [key=value ...]
build_url() {
  local host="$1" path="${2:-}" url qs='' sep='?'
  shift 2 || shift "$#"
  url="claude://${host}${path}"
  while [[ $# -gt 0 ]]; do
    local kv="$1"
    shift
    local key="${kv%%=*}" val="${kv#*=}"
    [[ -z "$val" ]] && continue
    qs+="${sep}$(urlencode "$key")=$(urlencode "$val")"
    sep='&'
  done
  printf '%s%s' "$url" "$qs"
}

normalize_url() {
  local url
  url="$(printf '%s' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if [[ "$url" == claude://* ]]; then
    printf '%s' "$url"
    return
  fi
  if [[ "$url" == https://claude.ai/* ]]; then
    printf 'claude://%s' "${url#https://}"
    return
  fi
  # Strip leading slashes then check for claude.ai/ prefix
  local stripped="${url#/}"
  if [[ "$stripped" == claude.ai/* ]]; then
    printf 'claude://%s' "$stripped"
    return
  fi
  printf 'claude://claude.ai/%s' "$stripped"
}

resolve_prompt() {
  local text="$1"
  if [[ "$text" == '-' ]]; then
    text="$(cat)"
  fi
  if [[ ${#text} -gt $MAX_PROMPT_LEN ]]; then
    echo >&2 "Prompt truncated to ${MAX_PROMPT_LEN} chars (${#text} given)"
    text="${text:0:$MAX_PROMPT_LEN}"
  fi
  printf '%s' "$text"
}

is_url_like() {
  [[ "$1" == https://* || "$1" == claude://* || "$1" == claude.ai/* || "$1" == /claude.ai/* ]]
}

# --------------------------------------------------------------------------- #
# Usage
# --------------------------------------------------------------------------- #

usage() {
  cat <<'EOF'
Usage: claude-desktop <command> [args]

Open Claude Desktop views via deep-link URIs.

Commands:
  open <url>                     Normalize and open a claude.ai URL
  new [PROMPT...] [-q QUERY]     Open new conversation, optionally with prompt
  chat <UUID>                    Open a conversation by UUID
  project <UUID>                 Open a project by UUID
  recents                        Open recents view
  code [scheduled]               Open Claude Code desktop view
  cowork [PROMPT] [-q|-f|-d]     Open cowork new session
  resume <UUID> [--cwd DIR]      Resume a session by UUID
  settings [PAGE]                Open settings page
  customize [skills|connectors]  Open customize view
  console                        Open platform.claude.com in browser
  logout                         Open logout page

Pass -h or --help after a command for detailed usage.
EOF
}

usage_open() {
  cat <<'EOF'
Usage: claude-desktop open [URL]

Open Claude Desktop from any claude.ai URL or path.

Accepted forms:
  https://claude.ai/...    Full HTTPS URL
  claude://...             Claude deep-link URL
  /claude.ai/..            Domain-relative
  /chat/...                Bare path (relative to claude.ai)
EOF
}

usage_new() {
  cat <<'EOF'
Usage: claude-desktop new [PROMPT...] [-q QUERY]

Open a new conversation, optionally pre-filled with a prompt.

Positional arguments are joined with spaces into the prompt text.

Options:
  -q, --query QUERY    Prompt text (use '-' to read from stdin)
EOF
}

usage_chat() {
  cat <<'EOF'
Usage: claude-desktop chat <UUID>

Open a conversation by its UUID.
EOF
}

usage_project() {
  cat <<'EOF'
Usage: claude-desktop project <UUID>

Open a project by its UUID.
EOF
}

usage_recents() {
  cat <<'EOF'
Usage: claude-desktop recents

Open the recents view.
EOF
}

usage_code() {
  cat <<'EOF'
Usage: claude-desktop code [scheduled]

Open Claude Code desktop view.

Subcommands:
  scheduled    Open the scheduled tasks view
EOF
}

usage_cowork() {
  cat <<'EOF'
Usage: claude-desktop cowork [PROMPT] [-q QUERY] [-f FILE...] [-d FOLDER...]

Open a new cowork session.

Options:
  -q, --query QUERY      Prompt text (use '-' to read from stdin)
  -f, --file FILE        Attach a file (repeatable)
  -d, --folder FOLDER    Attach a folder (repeatable)
EOF
}

usage_resume() {
  cat <<'EOF'
Usage: claude-desktop resume <UUID> [--cwd DIR]

Resume a Claude Code session by UUID.

Options:
  --cwd DIR    Working directory for resumed session
EOF
}

usage_settings() {
  cat <<'EOF'
Usage: claude-desktop settings [PAGE]

Open settings, optionally to a specific page.

Valid pages:
  general  account  usage  capabilities  connectors  claude-code
  cowork   desktop  desktop/extensions  desktop/developer
EOF
}

usage_customize() {
  cat <<'EOF'
Usage: claude-desktop customize [skills|connectors]

Open customize view, optionally to a sub-page.

Subcommands:
  skills      Open skills customize page
  connectors  Open connectors customize page
EOF
}

usage_console() {
  cat <<'EOF'
Usage: claude-desktop console

Open https://platform.claude.com/ in the default browser.
EOF
}

usage_logout() {
  cat <<'EOF'
Usage: claude-desktop logout

Open the Claude logout page.
EOF
}

# --------------------------------------------------------------------------- #
# Commands
# --------------------------------------------------------------------------- #

cmd_open() {
  [[ "${1:-}" == '-h' || "${1:-}" == '--help' ]] && {
    usage_open
    return
  }
  open_url "$(normalize_url "${1:-/}")"
}

cmd_new() {
  local -a words=()
  local query=''
  while [[ $# -gt 0 ]]; do
    case $1 in
    -h | --help)
      usage_new
      return
      ;;
    -q | --query)
      shift
      query="${1:-}"
      ;;
    -*)
      echo >&2 "Unknown option: $1"
      exit 1
      ;;
    *)
      words+=("$1")
      ;;
    esac
    shift
  done
  local prompt="${words[*]}"
  local text
  text="$(resolve_prompt "${prompt:-$query}")"
  open_url "$(build_url 'claude.ai' '/new' "q=${text}")"
}

cmd_chat() {
  [[ "${1:-}" == '-h' || "${1:-}" == '--help' ]] && {
    usage_chat
    return
  }
  [[ $# -lt 1 ]] && {
    usage_chat >&2
    exit 1
  }
  require_uuid "$1" 'conversation UUID'
  open_url "$(build_url 'claude.ai' "/chat/$1")"
}

cmd_project() {
  [[ "${1:-}" == '-h' || "${1:-}" == '--help' ]] && {
    usage_project
    return
  }
  [[ $# -lt 1 ]] && {
    usage_project >&2
    exit 1
  }
  require_uuid "$1" 'project UUID'
  open_url "$(build_url 'claude.ai' "/project/$1")"
}

cmd_recents() {
  [[ "${1:-}" == '-h' || "${1:-}" == '--help' ]] && {
    usage_recents
    return
  }
  open_url "$(build_url 'claude.ai' '/recents')"
}

cmd_code() {
  case "${1:-}" in
  -h | --help)
    usage_code
    return
    ;;
  scheduled) open_url "$(build_url 'claude.ai' '/claude-code-desktop/scheduled')" ;;
  '') open_url "$(build_url 'claude.ai' '/claude-code-desktop')" ;;
  *)
    echo >&2 "Unknown subcommand: $1"
    usage_code >&2
    exit 1
    ;;
  esac
}

cmd_cowork() {
  local prompt='' query=''
  local -a files=() folders=()
  while [[ $# -gt 0 ]]; do
    case $1 in
    -h | --help)
      usage_cowork
      return
      ;;
    -q | --query)
      shift
      query="${1:-}"
      ;;
    -f | --file)
      shift
      files+=("${1:-}")
      ;;
    -d | --folder)
      shift
      folders+=("${1:-}")
      ;;
    -*)
      echo >&2 "Unknown option: $1"
      exit 1
      ;;
    *)
      [[ -n "$prompt" ]] && {
        echo >&2 "Unexpected argument: $1"
        exit 1
      }
      prompt="$1"
      ;;
    esac
    shift
  done
  local text
  text="$(resolve_prompt "${prompt:-$query}")"

  # Build URL with potentially multiple file= and folder= params
  local url="claude://cowork/new" sep='?'
  if [[ -n "$text" ]]; then
    url+="${sep}q=$(urlencode "$text")"
    sep='&'
  fi
  for f in "${files[@]+"${files[@]}"}"; do
    url+="${sep}file=$(urlencode "$f")"
    sep='&'
  done
  for d in "${folders[@]+"${folders[@]}"}"; do
    url+="${sep}folder=$(urlencode "$d")"
    sep='&'
  done
  open_url "$url"
}

cmd_resume() {
  local session_id='' cwd=''
  while [[ $# -gt 0 ]]; do
    case $1 in
    -h | --help)
      usage_resume
      return
      ;;
    --cwd)
      shift
      cwd="${1:-}"
      ;;
    -*)
      echo >&2 "Unknown option: $1"
      exit 1
      ;;
    *)
      [[ -n "$session_id" ]] && {
        echo >&2 "Unexpected argument: $1"
        exit 1
      }
      session_id="$1"
      ;;
    esac
    shift
  done
  [[ -z "$session_id" ]] && {
    usage_resume >&2
    exit 1
  }
  require_uuid "$session_id" 'session UUID'
  local url
  url="$(build_url 'resume' '' "session=${session_id}")"
  if [[ -n "$cwd" ]]; then
    url+="&$(urlencode 'cwd')=$(urlencode "$cwd")"
  fi
  open_url "$url"
}

cmd_settings() {
  case "${1:-}" in
  -h | --help)
    usage_settings
    return
    ;;
  '')
    open_url "$(build_url 'claude.ai' '/settings')"
    ;;
  *)
    local page="$1"
    local valid=0
    for p in $SETTINGS_PAGES; do
      [[ "$p" == "$page" ]] && valid=1 && break
    done
    if [[ $valid -eq 0 ]]; then
      echo >&2 "Invalid settings page: $page"
      echo >&2 "Valid pages: $SETTINGS_PAGES"
      exit 1
    fi
    open_url "$(build_url 'claude.ai' "/settings/$page")"
    ;;
  esac
}

cmd_customize() {
  case "${1:-}" in
  -h | --help)
    usage_customize
    return
    ;;
  '') open_url "$(build_url 'claude.ai' '/customize')" ;;
  skills) open_url "$(build_url 'claude.ai' '/customize/skills')" ;;
  connectors) open_url "$(build_url 'claude.ai' '/customize/connectors')" ;;
  *)
    echo >&2 "Unknown subcommand: $1"
    usage_customize >&2
    exit 1
    ;;
  esac
}

cmd_console() {
  [[ "${1:-}" == '-h' || "${1:-}" == '--help' ]] && {
    usage_console
    return
  }
  open_url 'https://platform.claude.com/'
}

cmd_logout() {
  [[ "${1:-}" == '-h' || "${1:-}" == '--help' ]] && {
    usage_logout
    return
  }
  open_url "$(build_url 'claude.ai' '/logout')"
}

# --------------------------------------------------------------------------- #
# Main dispatch
# --------------------------------------------------------------------------- #

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  case "$1" in
  -h | --help)
    usage
    exit 0
    ;;
  esac

  # URL-like first arg → implicit `open`
  if is_url_like "$1"; then
    cmd_open "$@"
    return
  fi

  local cmd="$1"
  shift
  case "$cmd" in
  open) cmd_open "$@" ;;
  new) cmd_new "$@" ;;
  chat) cmd_chat "$@" ;;
  project) cmd_project "$@" ;;
  recents) cmd_recents "$@" ;;
  code) cmd_code "$@" ;;
  cowork) cmd_cowork "$@" ;;
  resume) cmd_resume "$@" ;;
  settings) cmd_settings "$@" ;;
  customize) cmd_customize "$@" ;;
  console) cmd_console "$@" ;;
  logout) cmd_logout "$@" ;;
  *)
    echo >&2 "Unknown command: $cmd"
    usage >&2
    exit 1
    ;;
  esac
}

[[ "${CLAUDE_DESKTOP_SOURCED:-}" == '1' ]] || main "$@"
