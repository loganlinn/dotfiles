#!/usr/bin/env bash
set -euo pipefail

require() { hash "$1" &>/dev/null || { echo >&2 "required: $1"; exit 1; }; }
require gum
require git

current_date=$(git log -1 --format='%ai')
echo >&2 "Current date: $current_date"

part=$(gum choose --header="Which part to change?" "date" "time" "both")

current_d=$(git log -1 --format='%ad' --date='format:%Y-%m-%d')
current_t=$(git log -1 --format='%ad' --date='format:%H:%M:%S')
current_tz=$(git log -1 --format='%ad' --date='format:%z')

case $part in
  date)
    new_d=$(gum input --header="New date" --placeholder="YYYY-MM-DD" --value="$current_d")
    new_date="${new_d} ${current_t} ${current_tz}"
    ;;
  time)
    new_t=$(gum input --header="New time" --placeholder="HH:MM:SS" --value="$current_t")
    new_date="${current_d} ${new_t} ${current_tz}"
    ;;
  both)
    new_d=$(gum input --header="New date" --placeholder="YYYY-MM-DD" --value="$current_d")
    new_t=$(gum input --header="New time" --placeholder="HH:MM:SS" --value="$current_t")
    new_date="${new_d} ${new_t} ${current_tz}"
    ;;
esac

echo >&2 "New date: $new_date"
gum confirm "Amend last commit with this date?" || exit 0

GIT_COMMITTER_DATE="$new_date" git commit --amend --no-edit --date="$new_date"
