#!/usr/bin/env bash
# Pick code blocks from markdown via fzf, copy to clipboard.
# Usage: mdcopy [FILE...]   (no args or '-' = stdin)

set -euo pipefail

require() { hash "$1" &>/dev/null || {
  echo >&2 "required: $1"
  exit 1
}; }
require mdq
require fzf
require jq

clipboard_copy() {
  if command -v pbcopy >/dev/null; then pbcopy
  elif command -v wl-copy >/dev/null; then wl-copy
  elif command -v xclip >/dev/null; then xclip -selection clipboard
  elif command -v xsel >/dev/null; then xsel --clipboard --input
  else return 1
  fi
}

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

json=$(mdq '```' -o json "${@:--}")
count=$(jq '.items | length' <<<"$json")
if [[ $count -eq 0 ]]; then
  echo >&2 "no code blocks found"
  exit 1
fi

for i in $(seq 0 $((count - 1))); do
  jq -r --argjson i "$i" '.items[$i].code_block.code' <<<"$json" >"$tmp/$i"
done

preview='cat '"$tmp"'/{1}'
command -v bat >/dev/null && preview='bat --style=plain --color=always --language={2} '"$tmp"'/{1} 2>/dev/null || cat '"$tmp"'/{1}'

selected=$(
  jq -r '.items | to_entries[] |
    "\(.key)\t\(.value.code_block.language // "txt")\t\(.value.code_block.code | split("\n") | .[0])"' \
    <<<"$json" |
    fzf --multi \
      --delimiter=$'\t' \
      --with-nth=2,3 \
      --preview="$preview" \
      --header='tab: multi-select, enter: copy' |
    cut -f1
)

[[ -z "$selected" ]] && exit 130

output=$(
  first=1
  while IFS= read -r idx; do
    ((first)) || echo
    cat "$tmp/$idx"
    first=0
  done <<<"$selected"
)

n=$(wc -l <<<"$selected" | tr -d ' ')
if [[ -t 1 ]] && printf '%s' "$output" | clipboard_copy 2>/dev/null; then
  echo >&2 "copied $n block(s) to clipboard"
else
  printf '%s\n' "$output"
fi
