#!/usr/bin/env bash
# Pick code blocks from markdown via fzf, copy to clipboard.
# Usage: mdcopy [FILE...]   (no args or '-' = stdin)

set -euo pipefail

require() { hash "$1" &>/dev/null || {
  echo >&2 "required: $1"
  exit 1
}; }
require fzf
require jq

if ! command -v mdq >/dev/null; then
  if command -v mise >/dev/null; then
    mdq() { mise exec github:yshavit/mdq -- mdq "$@"; }
  else
    echo >&2 "required: mdq (or mise to fetch it on demand)"
    exit 1
  fi
fi

clipboard_copy() {
  if command -v pbcopy >/dev/null; then pbcopy
  elif command -v wl-copy >/dev/null; then wl-copy
  elif command -v xclip >/dev/null; then xclip -selection clipboard
  elif command -v xsel >/dev/null; then xsel --clipboard --input
  else return 1
  fi
}

edit_content() {
  if command -v vipe >/dev/null; then
    vipe
  else
    local f="$tmp/__edit__.md"
    cat >"$f"
    "${EDITOR:-nano}" "$f" </dev/tty >/dev/tty
    cat "$f"
  fi
}

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

# Capture full input so the "entire document" entry can reference it.
input_file="$tmp/__all__"
if [[ $# -eq 0 ]]; then
  cat >"$input_file"
else
  cat "$@" >"$input_file"
fi

json=$(mdq '```' -o json "$input_file")
count=$(jq '.items | length' <<<"$json")
if [[ $count -eq 0 ]]; then
  echo >&2 "no code blocks found"
  exit 1
fi

for i in $(seq 0 $((count - 1))); do
  jq -r --argjson i "$i" '.items[$i].code_block.code' <<<"$json" >"$tmp/$i"
done

preview='cat '"$tmp"'/{1}'
command -v bat >/dev/null && preview='bat --style=plain --color=always --language={2} '"$tmp"'/{1} 2>/dev/null || cat '"$tmp"'/{1}'

menu=$(
  printf '__all__\tmd\t(entire document)\n'
  jq -r '.items | to_entries[] |
    "\(.key)\t\(.value.code_block.language // "txt")\t\(.value.code_block.code | split("\n") | .[0])"' \
    <<<"$json"
)

result=$(
  fzf --multi \
    --delimiter=$'\t' \
    --with-nth=2,3 \
    --preview="$preview" \
    --preview-window=down:50% \
    --expect=alt-enter \
    --header=$'tab: multi-select \u00b7 enter: copy \u00b7 alt-enter: edit then copy' \
    <<<"$menu"
) || exit 130

key=$(head -1 <<<"$result")
selected=$(tail -n +2 <<<"$result" | cut -f1)

[[ -z "$selected" ]] && exit 130

output=$(
  first=1
  while IFS= read -r idx; do
    ((first)) || echo
    cat "$tmp/$idx"
    first=0
  done <<<"$selected"
)

if [[ "$key" == "alt-enter" ]]; then
  output=$(printf '%s' "$output" | edit_content)
fi

n=$(wc -l <<<"$selected" | tr -d ' ')
if [[ -t 1 ]] && printf '%s' "$output" | clipboard_copy 2>/dev/null; then
  echo >&2 "copied $n selection(s) to clipboard"
else
  printf '%s\n' "$output"
fi
