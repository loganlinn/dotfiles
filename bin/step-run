#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo >&2 "Usage: step-run <script|-> [args...]"
  echo >&2 "Interactive script stepper — confirms each command before executing."
  echo >&2 "Use - to read script from stdin."
  echo >&2 ""
  echo >&2 "Controls:"
  echo >&2 "  (s)tep            execute command (flushes queue first)"
  echo >&2 "  (a)ccept          queue command for batch execution"
  echo >&2 "  (r)un [/pat/]     run remaining (or until pattern matches)"
  echo >&2 "  (j)ump [n=1]     jump over n commands (skip without executing)"
  echo >&2 "  (p)rint [n=5]    print next n lines of script (-n for previous)"
  echo >&2 "  (b)reak [<line>|/pat/]  add breakpoint"
  echo >&2 "    -l              list breakpoints"
  echo >&2 "    -d <id>         delete breakpoint"
  echo >&2 "  (w)atch <expr>   add watch expression"
  echo >&2 "    -l              list watches"
  echo >&2 "    -d <id>         delete watch"
  echo >&2 "  (d)iff           show env diff since last command"
  echo >&2 "  (t)race [n=20]   trace next n commands without executing"
  echo >&2 "  ! [expr]         execute an expression (opens \$EDITOR if expr omitted)"
  echo >&2 "  (q)uit"
  echo >&2 "  (h)elp / ?"
  exit 1
}

_resolve=1

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help) usage ;;
  --resolve) _resolve=1; shift ;;
  --no-resolve) _resolve=0; shift ;;
  --) shift; break ;;
  -*) echo >&2 "step-run: unknown option: $1"; usage ;;
  *) break ;;
  esac
done

[[ $# -lt 1 ]] && usage

if [[ "$1" == - ]]; then
  script="$(mktemp)"
  trap 'rm -f "$script"' EXIT
  cat >"$script"
elif [[ -f "$1" ]]; then
  script="$1"
elif (( _resolve )) && script="$(command -v "$1" 2>/dev/null)"; then
  :
else
  echo >&2 "step-run: not a file: $1"
  exit 1
fi
shift

# extdebug: returning 1 from DEBUG trap skips the command
shopt -s extdebug
# reset shell opts so sourced script starts with bash defaults
set +euo pipefail

_step_run_active=1
_step_run_cwd="$PWD"
_step_run_run_pattern=""
_step_run_jump=0
_step_run_queue=()

# derive tempfile extension from script name for syntax highlighting
_step_run_ext=".bash"
case "$script" in
*.sh) _step_run_ext=".sh" ;;
*.bash) _step_run_ext=".bash" ;;
*.zsh) _step_run_ext=".zsh" ;;
esac

# breakpoints: parallel arrays (line number or /pattern/)
_step_run_bp_lines=()
_step_run_bp_patterns=()

# watch expressions
_step_run_watches=()

# env snapshot for diff
_step_run_env_prev=""
_step_run_env_snap() {
  _step_run_env_prev="$(declare -p 2>/dev/null | grep -v '^declare -[^ ]* _step_run_')"
}
_step_run_env_snap

if command -v bat &>/dev/null; then
  _step_run_highlight() { bat --language bash --style=plain --paging=never --color=always <<<"$1" >&2; }
else
  _step_run_highlight() { echo >&2 "$1"; }
fi

_step_run_show_location() {
  printf >&2 "\033[2m%s:%s\033[0m " "$1" "$2"
  _step_run_highlight "$3"
}

_step_run_show_watches() {
  [[ ${#_step_run_watches[@]} -eq 0 ]] && return
  local i expr val
  for i in "${!_step_run_watches[@]}"; do
    expr="${_step_run_watches[$i]}"
    val="$(eval "$expr" 2>&1)" || true
    printf >&2 "  \033[33mwatch[%d]\033[0m %s = %s\n" "$i" "$expr" "$val"
  done
}

_step_run_hit_breakpoint() {
  local line="$1" cmd="$2" i
  for i in "${!_step_run_bp_lines[@]}"; do
    [[ "${_step_run_bp_lines[$i]}" == "$line" ]] && return 0
  done
  for i in "${!_step_run_bp_patterns[@]}"; do
    [[ "$cmd" == *"${_step_run_bp_patterns[$i]}"* ]] && return 0
  done
  return 1
}

_step_run_trap() {
  local cmd="$BASH_COMMAND"
  [[ "$cmd" == _step_run_* || "$cmd" == "source "* || "$cmd" == "shopt"* ]] && return 0

  local src="${BASH_SOURCE[1]:-unknown}" line="${BASH_LINENO[0]}"
  src="${src#"$_step_run_cwd"/}"

  # take env snapshot after previous command
  _step_run_env_snap

  # jump: skip remaining commands without prompting
  if (( _step_run_jump > 0 )); then
    (( _step_run_jump-- ))
    return 1
  fi

  # conditional run: stop when pattern matches
  if [[ -n "$_step_run_run_pattern" ]]; then
    if [[ "$cmd" == *"$_step_run_run_pattern"* ]]; then
      _step_run_run_pattern=""
      _step_run_active=1
    else
      return 0
    fi
  fi

  # free run: check breakpoints
  if [[ $_step_run_active -eq 0 ]]; then
    if _step_run_hit_breakpoint "$line" "$cmd"; then
      _step_run_active=1
      printf >&2 "\033[31m** breakpoint hit **\033[0m\n"
    else
      return 0
    fi
  fi

  _step_run_show_watches
  if (( ${#_step_run_queue[@]} )); then
    printf >&2 "\033[36m[%d queued]\033[0m " "${#_step_run_queue[@]}"
  fi
  _step_run_show_location "$src" "$line" "$cmd"

  while true; do
    read -rp "step-run [s,a,r,j,p,b,w,d,t,!,q,h] > " choice </dev/tty
    local _cmd="${choice%% *}" _args="${choice#* }"
    [[ "$_cmd" == "$_args" ]] && _args=""
    case "$_cmd" in
    "" | s | step)
      if (( ${#_step_run_queue[@]} )); then
        for _step_run_qcmd in "${_step_run_queue[@]}"; do
          eval "$_step_run_qcmd"
        done
        _step_run_queue=()
      fi
      return 0
      ;;
    a | accept)
      _step_run_queue+=("$cmd")
      printf >&2 "  \033[36mqueued\033[0m (%d)\n" "${#_step_run_queue[@]}"
      return 1
      ;;
    r | run)
      if [[ "$_args" == /* ]]; then
        _step_run_run_pattern="${_args#/}"
        _step_run_run_pattern="${_step_run_run_pattern%/}"
      else
        _step_run_active=0
      fi
      if (( ${#_step_run_queue[@]} )); then
        for _step_run_qcmd in "${_step_run_queue[@]}"; do
          eval "$_step_run_qcmd"
        done
        _step_run_queue=()
      fi
      return 0
      ;;
    j | jump)
      : "${_args:=1}"
      _step_run_jump=$((_args - 1))
      return 1
      ;;
    p | print)
      local _n="${_args:-5}" _from _to
      if (( _n > 0 )); then
        _from=$((line + 1))
        _to=$((line + _n))
      else
        _from=$((line + _n))
        (( _from < 1 )) && _from=1
        _to=$((line - 1))
      fi
      local _src="${BASH_SOURCE[1]}"
      if (( _from <= _to )) && [[ -f "$_src" ]]; then
        if command -v bat &>/dev/null; then
          bat --language bash --style=numbers --paging=never --color=always --line-range="${_from}:${_to}" "$_src" >&2
        else
          awk -v s="$_from" -v e="$_to" 'NR>=s&&NR<=e{printf "%5d\t%s\n",NR,$0}' "$_src" >&2
        fi
      fi
      ;;
    b | break)
      case "$_args" in
      "")
        echo >&2 "  usage: break [<line>|/pat/|-l|-d <id>]"
        ;;
      -l)
        if [[ ${#_step_run_bp_lines[@]} -eq 0 && ${#_step_run_bp_patterns[@]} -eq 0 ]]; then
          echo >&2 "  (no breakpoints)"
        else
          local i
          for i in "${!_step_run_bp_lines[@]}"; do
            printf >&2 "  \033[31mline[%d]\033[0m %s\n" "$i" "${_step_run_bp_lines[$i]}"
          done
          for i in "${!_step_run_bp_patterns[@]}"; do
            printf >&2 "  \033[31mpat[%d]\033[0m  /%s/\n" "$i" "${_step_run_bp_patterns[$i]}"
          done
        fi
        ;;
      -d\ *)
        local _arg="${_args#-d }"
        if [[ -n "${_step_run_bp_lines[$_arg]+x}" ]]; then
          unset '_step_run_bp_lines['"$_arg"']'
          echo >&2 "  deleted line breakpoint $_arg"
        elif [[ -n "${_step_run_bp_patterns[$_arg]+x}" ]]; then
          unset '_step_run_bp_patterns['"$_arg"']'
          echo >&2 "  deleted pattern breakpoint $_arg"
        else
          echo >&2 "  no breakpoint at index $_arg"
        fi
        ;;
      /*)
        local pat="${_args#/}"
        pat="${pat%/}"
        _step_run_bp_patterns+=("$pat")
        echo >&2 "  breakpoint pat[$(( ${#_step_run_bp_patterns[@]} - 1 ))] = /$pat/"
        ;;
      *)
        _step_run_bp_lines+=("$_args")
        echo >&2 "  breakpoint line[$(( ${#_step_run_bp_lines[@]} - 1 ))] = $_args"
        ;;
      esac
      ;;
    w | watch)
      case "$_args" in
      "")
        echo >&2 "  usage: watch <expr>|-l|-d <id>"
        ;;
      -l)
        if [[ ${#_step_run_watches[@]} -eq 0 ]]; then
          echo >&2 "  (no watches)"
        else
          local i val
          for i in "${!_step_run_watches[@]}"; do
            val="$(eval "${_step_run_watches[$i]}" 2>&1)" || true
            printf >&2 "  \033[33mwatch[%d]\033[0m %s = %s\n" "$i" "${_step_run_watches[$i]}" "$val"
          done
        fi
        ;;
      -d\ *)
        local _wi="${_args#-d }"
        if [[ -n "${_step_run_watches[$_wi]+x}" ]]; then
          unset '_step_run_watches['"$_wi"']'
          echo >&2 "  deleted watch $_wi"
        else
          echo >&2 "  no watch at index $_wi"
        fi
        ;;
      *)
        _step_run_watches+=("$_args")
        echo >&2 "  watch[$(( ${#_step_run_watches[@]} - 1 ))] = $_args"
        ;;
      esac
      ;;
    d | diff)
      local _env_now
      _env_now="$(declare -p 2>/dev/null | grep -v '^declare -[^ ]* _step_run_')"
      if command -v diff &>/dev/null; then
        diff --color=auto <(echo "$_step_run_env_prev") <(echo "$_env_now") >&2 || true
      else
        echo >&2 "$_env_now"
      fi
      ;;
    t | trace)
      local _tn="${_args:-20}" _tsrc="${BASH_SOURCE[1]}" _tcount
      _tcount=$(wc -l <"$_tsrc")
      local _tfrom=$((line + 1))
      local _tto=$((line + _tn))
      (( _tto > _tcount )) && _tto="$_tcount"
      if (( _tfrom <= _tto )); then
        echo >&2 "  trace: next $_tn lines (not executed):"
        if command -v bat &>/dev/null; then
          bat --language bash --style=numbers --paging=never --color=always --line-range="${_tfrom}:${_tto}" "$_tsrc" >&2
        else
          awk -v s="$_tfrom" -v e="$_tto" 'NR>=s&&NR<=e{printf "%5d\t%s\n",NR,$0}' "$_tsrc" >&2
        fi
      else
        echo >&2 "  (end of script)"
      fi
      ;;
    !)
      if [[ -n "$_args" ]]; then
        eval "$_args"
      else
        _step_run_tmp="$(mktemp "${TMPDIR:-/tmp}/step-run-XXXXXX${_step_run_ext}")"
        if "${EDITOR:-nano}" "$_step_run_tmp" </dev/tty >/dev/tty; then
          eval "$(cat "$_step_run_tmp")"
        fi
        rm -f "$_step_run_tmp"
      fi
      _step_run_show_watches
      _step_run_show_location "$src" "$line" "$cmd"
      ;;
    q | quit) exit 130 ;;
    h | help | \?)
      echo >&2 "  (s)tep            execute command (flushes queue first)"
      echo >&2 "  (a)ccept          queue command for batch execution"
      echo >&2 "  (r)un [/pat/]     run remaining (or until pattern matches)"
      echo >&2 "  (j)ump [n=1]     jump over n commands (skip without executing)"
      echo >&2 "  (p)rint [n=5]    print next n lines (-n for previous)"
      echo >&2 "  (b)reak [<line>|/pat/]  add breakpoint"
      echo >&2 "    -l              list breakpoints"
      echo >&2 "    -d <id>         delete breakpoint"
      echo >&2 "  (w)atch <expr>   add watch expression (eval'd each step)"
      echo >&2 "    -l              list watches"
      echo >&2 "    -d <id>         delete watch"
      echo >&2 "  (d)iff           show env diff since last command"
      echo >&2 "  (t)race [n=20]   trace next n commands without executing"
      echo >&2 "  ! [expr]         execute an expression (opens \$EDITOR if expr omitted)"
      echo >&2 "  (q)uit"
      ;;
    *) echo >&2 "  unknown command; type h for help" ;;
    esac
  done
}
trap '_step_run_trap' DEBUG

source "$script" "$@"
